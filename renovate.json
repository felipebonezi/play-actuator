{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "dependencyDashboard": true,
  "minimumReleaseAge": "14 days",
  "prCreation": "not-pending",
  "additionalBranchPrefix": "deps/",
  "addLabels": [
    "type:dependency"
  ],
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automergeStrategy": "rebase"
    }
  ]
}
